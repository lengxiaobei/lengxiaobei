# ── lengxiaobei 配置示例 ──────────────────────────────────────────
# 复制此文件为 .env 并填写实际值

# ── 后端服务 ──────────────────────────────────────────────────────
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# ── LLM 主模型 ───────────────────────────────────────────────────
LLM_PROVIDER=xiaomi
LLM_MODEL=mimo-v2.5-pro
LLM_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
LLM_API_KEY=tp-c81w27f5c7mlkmhuj2d74hqui5gtafikdaqon1vp21ud6h1a

# ── 多 Provider Fallback（可选）──────────────────────────────────
# 逗号分隔的 fallback provider 列表，按优先级排序
LLM_FALLBACKS=bailian,minimax,volcengine

# bailian provider
LLM_BAILIAN_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
LLM_BAILIAN_API_KEY=sk-sp-xxx
LLM_BAILIAN_MODELS=qwen3.5-plus,qwen3-coder-plus
LLM_BAILIAN_PROTOCOL=openai
LLM_BAILIAN_PRIORITY=80

# minimax provider
LLM_MINIMAX_BASE_URL=https://api.minimax.chat/v1
LLM_MINIMAX_API_KEY=sk-cp-xxx
LLM_MINIMAX_MODELS=MiniMax-M2.7,MiniMax-M2.7-highspeed
LLM_MINIMAX_PROTOCOL=openai
LLM_MINIMAX_PRIORITY=60

# volcengine provider
LLM_VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3
LLM_VOLCENGINE_API_KEY=18a192xxx
LLM_VOLCENGINE_MODELS=doubao-seed-2.0-pro,deepseek-v3.2
LLM_VOLCENGINE_PROTOCOL=openai
LLM_VOLCENGINE_PRIORITY=40

# ── MCP 服务器（可选）────────────────────────────────────────────
# JSON 格式的 MCP 服务器配置
# MCP_SERVERS_JSON=[{"name":"openclaw","url":"http://localhost:18789/mcp","transport":"sse"}]
OPENCLAW_MCP_URL=http://localhost:18789

# ── Skills 目录（可选）───────────────────────────────────────────
# 逗号分隔的 skills 目录路径
# SKILL_DIRS=/path/to/skills,/another/path

# ── Session 管理 ─────────────────────────────────────────────────
MAX_SESSIONS=50
SESSION_CONTEXT_TOKENS=200000

# ── Memory Hooks ─────────────────────────────────────────────────
MEMORY_AUTO_RECALL=true
MEMORY_MAX_RESULTS=5
MEMORY_PROMOTION_THRESHOLD=0.8

# ── 渠道（可选）──────────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# WHATSAPP_BRIDGE_URL=
# SLACK_BOT_TOKEN=
# SLACK_CHANNEL_ID=

# ── 数据存储 ─────────────────────────────────────────────────────
DATA_DIR=./data
DATABASE_URL=sqlite:///data/sqlite/agent.db
REDIS_URL=redis://127.0.0.1:6379/0
CHROMA_PATH=./data/chroma
