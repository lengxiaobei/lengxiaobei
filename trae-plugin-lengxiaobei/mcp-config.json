{
  "name": "Leng Xiaobei",
  "description": "冷小北 AI 助手",
  "type": "stdio",
  "command": ["python3", "/Users/panhao/projects/lengxiaobei/src/mcp_server.py"],
  "cwd": "/Users/panhao/projects/lengxiaobei",
  "env": {
    "PYTHONPATH": "${workspaceFolder}"
  },
  "methods": [
    {
      "name": "analyzeCode",
      "description": "分析代码",
      "params": {
        "type": "object",
        "properties": {
          "file": {
            "type": "string",
            "description": "要分析的文件路径"
          }
        },
        "required": ["file"]
      },
      "result": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "message": {
            "type": "string"
          },
          "analysis": {
            "type": "object"
          }
        }
      }
    },
    {
      "name": "generateCode",
      "description": "生成代码",
      "params": {
        "type": "object",
        "properties": {
          "prompt": {
            "type": "string",
            "description": "代码生成提示"
          }
        },
        "required": ["prompt"]
      },
      "result": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "message": {
            "type": "string"
          },
          "code": {
            "type": "string"
          }
        }
      }
    },
    {
      "name": "optimizeArchitecture",
      "description": "优化架构",
      "params": {
        "type": "object",
        "properties": {
          "project": {
            "type": "string",
            "description": "项目路径"
          }
        },
        "required": ["project"]
      },
      "result": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "message": {
            "type": "string"
          },
          "recommendations": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    {
      "name": "runEvolution",
      "description": "运行进化",
      "params": {
        "type": "object",
        "properties": {
          "project": {
            "type": "string",
            "description": "项目路径"
          }
        },
        "required": ["project"]
      },
      "result": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "message": {
            "type": "string"
          },
          "changes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    {
      "name": "health",
      "description": "健康检查",
      "params": {
        "type": "object"
      },
      "result": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "service": {
            "type": "string"
          }
        }
      }
    }
  ]
}
